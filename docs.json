{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "EssayGen Help Center",
  "colors": {
    "primary": "#4F46E5",
    "light": "#818CF8",
    "dark": "#3730A3"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Help Center",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Features",
            "pages": [
              "features/writer",
              "features/chat",
              "features/papers",
              "features/brand-books"
            ]
          },
          {
            "group": "Your Account",
            "pages": [
              "account/profile",
              "account/billing",
              "account/team"
            ]
          },
          {
            "group": "Support",
            "pages": [
              "support/faq",
              "support/tickets"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Open App",
          "href": "https://essaygen.ai",
          "icon": "arrow-up-right-from-square"
        },
        {
          "anchor": "Contact Support",
          "href": "mailto:support@essaygen.ai",
          "icon": "envelope"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@essaygen.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://essaygen.ai"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/essaygen"
    }
  }
}
